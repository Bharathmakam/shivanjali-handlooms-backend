# Required: PostgreSQL database used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/shivanjali_handlooms?schema=public"

# Required for JWT auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"

# Optional: Razorpay live/test credentials
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="replace-with-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="replace-with-webhook-secret"

# Optional: Cloudflare R2 product image uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
R2_S3_ENDPOINT=""

# Optional: Interakt / WhatsApp CRM provider
INTERAKT_API_URL="https://api.interakt.ai"
INTERAKT_API_KEY="replace-with-interakt-api-key"

# Backend port
PORT="3001"